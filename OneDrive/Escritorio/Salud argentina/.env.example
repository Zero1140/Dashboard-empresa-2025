# ============================================================
# SaludOS Argentina — Variables de entorno
# Copiar a .env y completar los valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# --- App ---
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Base de datos ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=saludos
POSTGRES_PASSWORD=saludos_dev
POSTGRES_DB=saludos_db
DATABASE_URL=postgresql+asyncpg://saludos:saludos_dev@db:5432/saludos_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ============================================================
# ⚠️  INTEGRACIONES EXTERNAS — MODO MOCK ACTIVO
# Cambiar a false cuando lleguen las credenciales reales
# Ver PENDING_INTEGRATIONS.md para instrucciones completas
# ============================================================

# --- REFEPS / SISA ---
# Estado: ⚠️ MOCK — Credenciales pendientes vía Formulario A1
# Contacto: soporte@sisa.msal.gov.ar | Asunto: "Solicitud acceso WS REFEPS"
# Tiempo estimado: 4–12 semanas desde el envío del formulario
REFEPS_MOCK_MODE=true
REFEPS_WS_URL=https://sisa.msal.gov.ar/sisa/services/profesionalService
REFEPS_REST_URL=https://sisa.msal.gov.ar/sisa/services/rest/profesional/buscar
REFEPS_USERNAME=                # Dejar vacío hasta recibir credenciales SISA
REFEPS_PASSWORD=                # Dejar vacío hasta recibir credenciales SISA

# --- OSDE FHIR ---
# Estado: ⚠️ MOCK — Sandbox disponible HOY (sin credenciales para staging)
# Registrarse en: osde.com.ar/interoperabilidad/conectar-prescriptor-de-medicamentos
# Sandbox: sandbox.farmalink.com.ar/apis-docs/FARMALINK_RE/farmalink/v3
OSDE_MOCK_MODE=true
OSDE_FHIR_BASE_URL=https://sandbox.farmalink.com.ar/apis-docs/FARMALINK_RE/farmalink/v3
OSDE_CLIENT_ID=                 # Obtener tras registro en portal OSDE
OSDE_CLIENT_SECRET=             # Obtener tras NDA con equipo OSDE

# --- Farmalink Hub ---
# Estado: ⚠️ MOCK — Registro vía formulario MS Forms en farmalink.com.ar
# Cubre: Swiss Medical, Medifé, Omint, IOMA + 20 financiadores más
FARMALINK_MOCK_MODE=true
FARMALINK_BASE_URL=https://sandbox.farmalink.com.ar
FARMALINK_API_KEY=              # Obtener tras homologación Farmalink (4–6 semanas)

# ============================================================
# Celery
# ============================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email
RESEND_API_KEY=
INVITATION_SECRET=change-me-invitation-secret-32chars
FRONTEND_BASE_URL=http://localhost:3000

# ============================================================
# Encriptación en reposo (Ley 25.326)
# ============================================================
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=
